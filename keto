
<!DOCTYPE html>
<html lang="sr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Keto Dnevnik</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #1B2016;
    --bg-card: #242B1E;
    --bg-card-2: #2C3424;
    --line: #3A4530;
    --ivory: #F1EEE2;
    --muted: #93997F;
    --yolk: #E8A93B;
    --avocado: #86A050;
    --alert: #C1502E;
    --font-display: 'Fraunces', serif;
    --font-body: 'IBM Plex Sans', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }
  *{ box-sizing: border-box; }
  html,body{
    margin:0; padding:0;
    background: var(--bg);
    color: var(--ivory);
    font-family: var(--font-body);
    -webkit-tap-highlight-color: transparent;
  }
  body{ min-height:100vh; padding: 20px 16px 60px; }
  .wrap{ max-width: 480px; margin: 0 auto; }

  header{ display:flex; align-items:baseline; justify-content:space-between; margin-bottom: 20px; }
  h1{ font-family: var(--font-display); font-weight: 600; font-size: 26px; letter-spacing: -0.01em; margin: 0; }
  h1 span{ color: var(--yolk); font-style: italic; font-weight: 400; }
  .date{ font-family: var(--font-mono); font-size: 12px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.04em; }
  .gear{ background:none; border:none; color: var(--muted); cursor:pointer; font-size: 18px; padding: 4px 8px; line-height:1; }
  .gear:hover{ color: var(--ivory); }

  .dial-card{ background: var(--bg-card); border: 1px solid var(--line); border-radius: 20px; padding: 24px; display:flex; align-items:center; gap: 22px; margin-bottom: 16px; }
  .dial-svg{ flex-shrink:0; }
  .dial-num{ font-family: var(--font-mono); font-weight:600; font-size: 30px; fill: var(--ivory); }
  .dial-label{ font-family: var(--font-mono); font-size: 9px; fill: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .macro-list{ flex:1; display:flex; flex-direction:column; gap:10px; }
  .macro-row{ display:flex; justify-content:space-between; align-items:baseline; }
  .macro-name{ font-size: 13px; color: var(--muted); }
  .macro-val{ font-family: var(--font-mono); font-size: 15px; font-weight:600; }

  .settings-panel{ background: var(--bg-card); border: 1px solid var(--line); border-radius: 16px; padding: 16px; margin-bottom: 16px; display:none; gap: 10px; flex-direction: column; }
  .settings-panel.open{ display:flex; }
  .settings-row{ display:flex; align-items:center; justify-content:space-between; gap:10px; }
  .settings-row label{ font-size: 13px; color: var(--muted); }
  .settings-row input{ width: 80px; text-align:right; background: var(--bg-card-2); border:1px solid var(--line); border-radius:8px; color: var(--ivory); font-family: var(--font-mono); font-size:14px; padding: 6px 8px; }

  .section-title{ font-family: var(--font-mono); font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin: 22px 0 10px; }

  .search-box{ position: relative; margin-bottom: 10px; }
  .search-box input{ width:100%; background: var(--bg-card); border: 1px solid var(--line); border-radius: 14px; color: var(--ivory); font-family: var(--font-body); font-size: 16px; padding: 14px 16px; outline: none; }
  .search-box input:focus{ border-color: var(--avocado); }
  .search-box input::placeholder{ color: var(--muted); }

  .results{ display:flex; flex-direction:column; gap:6px; margin-bottom: 10px; }
  .result-item{ background: var(--bg-card); border: 1px solid var(--line); border-radius: 12px; padding: 12px 14px; display:flex; justify-content:space-between; align-items:center; cursor:pointer; }
  .result-item:active{ background: var(--bg-card-2); }
  .result-name{ font-size: 14px; }
  .result-macro{ font-family: var(--font-mono); font-size: 11px; color: var(--muted); }
  .add-custom{ text-align:center; font-size: 13px; color: var(--avocado); padding: 10px; cursor:pointer; border: 1px dashed var(--line); border-radius: 12px; }

  .selected-card{ background: var(--bg-card-2); border: 1px solid var(--avocado); border-radius: 14px; padding: 14px; margin-bottom: 16px; display:none; flex-direction: column; gap: 10px; }
  .selected-card.open{ display:flex; }
  .selected-top{ display:flex; justify-content:space-between; align-items:center; }
  .selected-name{ font-size: 15px; font-weight: 500; }
  .selected-close{ background:none; border:none; color:var(--muted); font-size:16px; cursor:pointer; }
  .gram-row{ display:flex; gap:8px; align-items:center; }
  .gram-row input{ flex:1; background: var(--bg-card); border:1px solid var(--line); border-radius:10px; color: var(--ivory); font-family: var(--font-mono); font-size:16px; padding: 10px 12px; text-align:center; }
  .btn-add{ background: var(--yolk); border:none; border-radius:10px; color:#1B2016; font-family: var(--font-body); font-weight:600; font-size:14px; padding: 10px 18px; cursor:pointer; }
  .btn-add:active{ opacity:0.85; }
  .preview{ font-family: var(--font-mono); font-size: 11px; color: var(--muted); text-align:center; }

  .custom-form{ background: var(--bg-card-2); border: 1px solid var(--yolk); border-radius: 14px; padding: 14px; margin-bottom: 16px; display:none; flex-direction: column; gap: 10px; }
  .custom-form.open{ display:flex; }
  .custom-form input{ background: var(--bg-card); border:1px solid var(--line); border-radius:10px; color: var(--ivory); font-family: var(--font-body); font-size:14px; padding: 10px 12px; }
  .custom-grid{ display:grid; grid-template-columns: 1fr 1fr 1fr; gap:8px; }
  .custom-grid label{ font-size:10px; color:var(--muted); font-family: var(--font-mono); display:block; margin-bottom:4px; }

  /* Meal tabs */
  .meal-tabs{ display:flex; gap: 8px; margin-bottom: 12px; }
  .meal-tab{ flex:1; background: var(--bg-card); border: 1px solid var(--line); border-radius: 12px; padding: 10px; text-align:center; font-size: 13px; color: var(--muted); cursor:pointer; }
  .meal-tab.active{ background: var(--bg-card-2); border-color: var(--avocado); color: var(--ivory); font-weight:600; }
  .meal-grid{ display:grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 16px; }
  .meal-btn{ background: var(--bg-card); border: 1px solid var(--line); border-radius: 12px; padding: 12px 10px; text-align:left; font-size: 13px; color: var(--ivory); cursor:pointer; line-height:1.3; }
  .meal-btn:active{ background: var(--bg-card-2); }
  .meal-btn .mb-carbs{ display:block; margin-top:4px; font-family: var(--font-mono); font-size: 10px; color: var(--muted); }

  .meal-detail{ background: var(--bg-card-2); border: 1px solid var(--yolk); border-radius: 14px; padding: 14px; margin-bottom: 16px; display:none; flex-direction: column; gap: 10px; }
  .meal-detail.open{ display:flex; }
  .meal-detail-top{ display:flex; justify-content:space-between; align-items:center; }
  .meal-detail-name{ font-size: 15px; font-weight: 600; }
  .meal-ing-list{ display:flex; flex-direction:column; gap:4px; }
  .meal-ing-row{ display:flex; justify-content:space-between; font-size: 12px; color: var(--muted); }
  .meal-totals{ font-family: var(--font-mono); font-size: 12px; color: var(--ivory); border-top: 1px solid var(--line); padding-top: 8px; }

  .log-item{ display:flex; justify-content:space-between; align-items:center; padding: 12px 14px; background: var(--bg-card); border: 1px solid var(--line); border-radius: 12px; margin-bottom: 8px; }
  .log-left{ display:flex; flex-direction:column; gap:2px; }
  .log-name{ font-size: 14px; }
  .log-grams{ font-family: var(--font-mono); font-size: 11px; color: var(--muted); }
  .log-right{ display:flex; align-items:center; gap: 10px; }
  .log-carbs{ font-family: var(--font-mono); font-size: 14px; font-weight:600; color: var(--yolk); }
  .log-remove{ background:none; border:none; color: var(--muted); font-size: 16px; cursor:pointer; padding:2px 6px; }
  .log-remove:hover{ color: var(--alert); }
  .empty-log{ text-align:center; color: var(--muted); font-size: 13px; padding: 24px 0; }

  .status-msg{ text-align:center; font-size:12px; color:var(--muted); margin-top: 10px; min-height:16px; }
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div>
      <h1>keto <span>dnevnik</span></h1>
      <div class="date" id="dateLabel">—</div>
    </div>
    <button class="gear" id="gearBtn" title="Podešavanja">⚙</button>
  </header>

  <div class="settings-panel" id="settingsPanel">
    <div class="settings-row">
      <label>Dnevni cilj neto UH (g)</label>
      <input type="number" id="goalInput" value="25" min="5" max="150">
    </div>
    <div class="settings-row">
      <button class="btn-add" id="saveGoalBtn" style="width:100%;">Sačuvaj</button>
    </div>
  </div>

  <div class="dial-card">
    <svg class="dial-svg" width="110" height="110" viewBox="0 0 110 110">
      <circle cx="55" cy="55" r="46" fill="none" stroke="#3A4530" stroke-width="10"/>
      <circle id="dialArc" cx="55" cy="55" r="46" fill="none" stroke="#86A050" stroke-width="10"
        stroke-linecap="round" transform="rotate(-90 55 55)" stroke-dasharray="289" stroke-dashoffset="289"/>
      <text x="55" y="52" text-anchor="middle" class="dial-num" id="dialNum">0</text>
      <text x="55" y="68" text-anchor="middle" class="dial-label" id="dialLabel">od 25g UH</text>
    </svg>
    <div class="macro-list">
      <div class="macro-row"><span class="macro-name">proteini</span><span class="macro-val" id="totalProtein">0 g</span></div>
      <div class="macro-row"><span class="macro-name">masti</span><span class="macro-val" id="totalFat">0 g</span></div>
      <div class="macro-row"><span class="macro-name">kalorije</span><span class="macro-val" id="totalCal">0 kcal</span></div>
    </div>
  </div>

  <div class="section-title">Pretraga namirnica</div>
  <div class="search-box">
    <input type="text" id="searchInput" placeholder="Šta si pojeo/la? npr. losos, avokado...">
  </div>
  <div class="results" id="resultsBox"></div>

  <div class="selected-card" id="selectedCard">
    <div class="selected-top">
      <div class="selected-name" id="selectedName"></div>
      <button class="selected-close" id="closeSelected">✕</button>
    </div>
    <div class="gram-row">
      <input type="number" id="gramsInput" placeholder="grama" inputmode="decimal">
      <button class="btn-add" id="addEntryBtn">Dodaj</button>
    </div>
    <div class="preview" id="previewText"></div>
  </div>

  <div class="custom-form" id="customForm">
    <input type="text" id="customName" placeholder="Naziv namirnice">
    <div class="custom-grid">
      <div><label>UH /100g</label><input type="number" id="customCarbs" step="0.1"></div>
      <div><label>Prot /100g</label><input type="number" id="customProtein" step="0.1"></div>
      <div><label>Masti /100g</label><input type="number" id="customFat" step="0.1"></div>
    </div>
    <button class="btn-add" id="saveCustomBtn">Sačuvaj namirnicu</button>
  </div>

  <div class="section-title">Predlozi obroka</div>
  <div class="meal-tabs" id="mealTabs">
    <div class="meal-tab active" data-cat="breakfast">Doručak</div>
    <div class="meal-tab" data-cat="lunch">Ručak</div>
    <div class="meal-tab" data-cat="dinner">Večera</div>
  </div>
  <div class="meal-grid" id="mealGrid"></div>

  <div class="meal-detail" id="mealDetail">
    <div class="meal-detail-top">
      <div class="meal-detail-name" id="mealDetailName"></div>
      <button class="selected-close" id="closeMealDetail">✕</button>
    </div>
    <div class="meal-ing-list" id="mealIngList"></div>
    <div class="meal-totals" id="mealTotals"></div>
    <button class="btn-add" id="addMealBtn">Dodaj ceo obrok u dnevnik</button>
  </div>

  <div class="section-title">Danas pojedeno</div>
  <div id="logList"></div>

  <div class="status-msg" id="statusMsg"></div>

</div>

