};

// ---------- State ----------
let customFoods = [];
let settings = { goal: 25 };
let todayEntries = [];
let selectedFood = null;
let activeMealCat = "breakfast";
let selectedMeal = null;
const CIRC = 2 * Math.PI * 46; // ~289

function todayKey(){
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth()+1).padStart(2,'0');
  const day = String(d.getDate()).padStart(2,'0');
  return `keto:log:${y}-${m}-${day}`;
}
function todayLabel(){
  const d = new Date();
  return d.toLocaleDateString('sr-RS', { weekday:'long', day:'numeric', month:'long' });
}

function setStatus(msg, isError){
  const el = document.getElementById('statusMsg');
  el.textContent = msg || '';
  el.style.color = isError ? 'var(--alert)' : 'var(--muted)';
  if(msg){ setTimeout(()=>{ if(el.textContent===msg) el.textContent=''; }, 2500); }
}

// ---------- Local storage helpers ----------
function lsGet(key){
  try{
    const raw = localStorage.getItem(key);
    return raw ? JSON.parse(raw) : null;
  }catch(e){ return null; }
}
function lsSet(key, value){
  try{
    localStorage.setItem(key, JSON.stringify(value));
    return true;
  }catch(e){
    setStatus('Greška pri čuvanju (localStorage nedostupan)', true);
    return false;
  }
}

function loadSettings(){
  const s = lsGet('keto:settings');
  if(s){ settings = s; }
  document.getElementById('goalInput').value = settings.goal;
}
function saveSettings(){ lsSet('keto:settings', settings); }

function loadCustomFoods(){
  const c = lsGet('keto:custom-foods');
  customFoods = c || [];
}
function saveCustomFoods(){ lsSet('keto:custom-foods', customFoods); }

function loadToday(){
  const t = lsGet(todayKey());
  todayEntries = t || [];
}
function saveToday(){ lsSet(todayKey(), todayEntries); }

// ---------- Lookup ----------
function allFoods(){ return [...FOOD_DB, ...customFoods]; }
function findFood(name){ return allFoods().find(f => f.n === name); }

// ---------- Rendering: search ----------
function renderResults(query){
  const box = document.getElementById('resultsBox');
  box.innerHTML = '';
  if(!query || query.trim().length === 0){ return; }
  const q = query.toLowerCase().trim();
  const matches = allFoods().filter(f => f.n.toLowerCase().includes(q)).slice(0, 6);
  matches.forEach(f=>{
    const div = document.createElement('div');
    div.className = 'result-item';
    div.innerHTML = `<span class="result-name">${f.n}</span><span class="result-macro">${f.c}g UH /100g</span>`;
    div.addEventListener('click', ()=> selectFood(f));
    box.appendChild(div);
  });
  const addCustom = document.createElement('div');
  addCustom.className = 'add-custom';
  addCustom.textContent = matches.length ? '+ Namirnica nije na listi? Dodaj custom' : '+ Nema rezultata — dodaj custom namirnicu';
  addCustom.addEventListener('click', ()=>{
    document.getElementById('customForm').classList.add('open');
    document.getElementById('customName').value = query;
    document.getElementById('customName').focus();
  });
  box.appendChild(addCustom);
}

function selectFood(f){
  selectedFood = f;
  document.getElementById('selectedName').textContent = f.n;
  document.getElementById('selectedCard').classList.add('open');
  document.getElementById('gramsInput').value = '';
  document.getElementById('previewText').textContent = '';
  document.getElementById('gramsInput').focus();
}

function updatePreview(){
  if(!selectedFood) return;
  const g = parseFloat(document.getElementById('gramsInput').value) || 0;
  const c = (selectedFood.c * g / 100).toFixed(1);
  const p = (selectedFood.p * g / 100).toFixed(1);
  const f = (selectedFood.f * g / 100).toFixed(1);
  document.getElementById('previewText').textContent = g > 0 ? `≈ ${c}g UH · ${p}g proteina · ${f}g masti` : '';
}

// ---------- Rendering: meals ----------
function mealTotals(meal){
  let c=0,p=0,f=0;
  meal.items.forEach(it=>{
    const food = findFood(it.n);
    if(!food) return;
    c += food.c * it.g / 100;
    p += food.p * it.g / 100;
    f += food.f * it.g / 100;
  });
  const cal = c*4 + p*4 + f*9;
  return {c,p,f,cal};
}

function renderMealGrid(){
  const grid = document.getElementById('mealGrid');
  grid.innerHTML = '';
  MEALS[activeMealCat].forEach(meal=>{
    const t = mealTotals(meal);
    const btn = document.createElement('div');
    btn.className = 'meal-btn';
    btn.innerHTML = `${meal.name}<span class="mb-carbs">${t.c.toFixed(1)}g UH · ${t.cal.toFixed(0)} kcal</span>`;
    btn.addEventListener('click', ()=> selectMeal(meal));
    grid.appendChild(btn);
  });
}

function selectMeal(meal){
  selectedMeal = meal;
  document.getElementById('mealDetailName').textContent = meal.name;
  const list = document.getElementById('mealIngList');
  list.innerHTML = '';
  meal.items.forEach(it=>{
    const row = document.createElement('div');
    row.className = 'meal-ing-row';
    row.innerHTML = `<span>${it.n}</span><span>${it.g}g</span>`;
    list.appendChild(row);
  });
  const t = mealTotals(meal);
  document.getElementById('mealTotals').textContent =
    `Ukupno: ${t.c.toFixed(1)}g UH · ${t.p.toFixed(1)}g proteina · ${t.f.toFixed(1)}g masti · ${t.cal.toFixed(0)} kcal`;
  document.getElementById('mealDetail').classList.add('open');
}

// ---------- Rendering: log ----------
function renderLog(){
  const list = document.getElementById('logList');
  list.innerHTML = '';
  if(todayEntries.length === 0){
    list.innerHTML = '<div class="empty-log">Još ništa uneto danas.</div>';
  } else {
    todayEntries.slice().reverse().forEach(entry=>{
      const div = document.createElement('div');
      div.className = 'log-item';
      const gramsLabel = entry.type === 'meal' ? `obrok · ${entry.itemCount} sastojka` : `${entry.grams}g`;
      div.innerHTML = `
        <div class="log-left">
          <span class="log-name">${entry.name}</span>
          <span class="log-grams">${gramsLabel}</span>
        </div>
        <div class="log-right">
          <span class="log-carbs">${entry.carbs.toFixed(1)}g</span>
          <button class="log-remove" data-id="${entry.id}">✕</button>
        </div>`;
      list.appendChild(div);
    });
    list.querySelectorAll('.log-remove').forEach(btn=>{
      btn.addEventListener('click', ()=>{
        const id = btn.getAttribute('data-id');
        todayEntries = todayEntries.filter(e => String(e.id) !== id);
        saveToday();
        renderAll();
      });
    });
  }
  renderTotals();
}

function renderTotals(){
  const totalCarbs = todayEntries.reduce((s,e)=>s+e.carbs,0);
  const totalProtein = todayEntries.reduce((s,e)=>s+e.protein,0);
  const totalFat = todayEntries.reduce((s,e)=>s+e.fat,0);
  const totalCal = todayEntries.reduce((s,e)=>s+e.cal,0);

  document.getElementById('totalProtein').textContent = totalProtein.toFixed(0) + ' g';
  document.getElementById('totalFat').textContent = totalFat.toFixed(0) + ' g';
  document.getElementById('totalCal').textContent = totalCal.toFixed(0) + ' kcal';

  const goal = settings.goal || 25;
  const pct = Math.min(totalCarbs / goal, 1);
  const arc = document.getElementById('dialArc');
  arc.setAttribute('stroke-dashoffset', CIRC - pct * CIRC);
  arc.setAttribute('stroke', totalCarbs > goal ? '#C1502E' : '#86A050');

  document.getElementById('dialNum').textContent = totalCarbs.toFixed(0);
  document.getElementById('dialLabel').textContent = `od ${goal}g UH`;
}

function renderAll(){
  document.getElementById('dateLabel').textContent = todayLabel();
  renderLog();
  renderMealGrid();
}

// ---------- Events: search & custom food ----------
document.getElementById('searchInput').addEventListener('input', (e)=> renderResults(e.target.value));

document.getElementById('closeSelected').addEventListener('click', ()=>{
  selectedFood = null;
  document.getElementById('selectedCard').classList.remove('open');
});

document.getElementById('gramsInput').addEventListener('input', updatePreview);

document.getElementById('addEntryBtn').addEventListener('click', ()=>{
  if(!selectedFood){ return; }
  const g = parseFloat(document.getElementById('gramsInput').value);
  if(!g || g <= 0){ setStatus('Unesi gramažu', true); return; }
  const carbs = selectedFood.c * g / 100;
  const protein = selectedFood.p * g / 100;
  const fat = selectedFood.f * g / 100;
  const cal = carbs*4 + protein*4 + fat*9;
  todayEntries.push({ id: Date.now(), type:'food', name: selectedFood.n, grams: g, carbs, protein, fat, cal });
  saveToday();
  selectedFood = null;
  document.getElementById('selectedCard').classList.remove('open');
  document.getElementById('searchInput').value = '';
  document.getElementById('resultsBox').innerHTML = '';
  setStatus('Dodato ✓');
  renderAll();
});

document.getElementById('saveCustomBtn').addEventListener('click', ()=>{
  const name = document.getElementById('customName').value.trim();
  const c = parseFloat(document.getElementById('customCarbs').value) || 0;
  const p = parseFloat(document.getElementById('customProtein').value) || 0;
  const f = parseFloat(document.getElementById('customFat').value) || 0;
  if(!name){ setStatus('Unesi naziv namirnice', true); return; }
  const newFood = { n: name, c, p, f };
  customFoods.push(newFood);
  saveCustomFoods();
  document.getElementById('customForm').classList.remove('open');
  document.getElementById('customName').value = '';
  document.getElementById('customCarbs').value = '';
  document.getElementById('customProtein').value = '';
  document.getElementById('customFat').value = '';
  setStatus('Namirnica sačuvana ✓');
  selectFood(newFood);
});

// ---------- Events: settings ----------
document.getElementById('gearBtn').addEventListener('click', ()=>{
  document.getElementById('settingsPanel').classList.toggle('open');
});

document.getElementById('saveGoalBtn').addEventListener('click', ()=>{
  const g = parseFloat(document.getElementById('goalInput').value);
  if(!g || g <= 0){ setStatus('Unesi validan cilj', true); return; }
  settings.goal = g;
  saveSettings();
  document.getElementById('settingsPanel').classList.remove('open');
  setStatus('Cilj sačuvan ✓');
  renderTotals();
});

// ---------- Events: meals ----------
document.getElementById('mealTabs').addEventListener('click', (e)=>{
  const tab = e.target.closest('.meal-tab');
  if(!tab) return;
  activeMealCat = tab.getAttribute('data-cat');
  document.querySelectorAll('.meal-tab').forEach(t=>t.classList.remove('active'));
  tab.classList.add('active');
  document.getElementById('mealDetail').classList.remove('open');
  renderMealGrid();
});

document.getElementById('closeMealDetail').addEventListener('click', ()=>{
  selectedMeal = null;
  document.getElementById('mealDetail').classList.remove('open');
});

document.getElementById('addMealBtn').addEventListener('click', ()=>{
  if(!selectedMeal) return;
  const t = mealTotals(selectedMeal);
  todayEntries.push({
    id: Date.now(),
    type:'meal',
    name: selectedMeal.name,
    itemCount: selectedMeal.items.length,
    carbs: t.c, protein: t.p, fat: t.f, cal: t.cal
  });
  saveToday();
  selectedMeal = null;
  document.getElementById('mealDetail').classList.remove('open');
  setStatus('Obrok dodat ✓');
  renderAll();
});

// ---------- Init ----------
(function init(){
  loadSettings();
  loadCustomFoods();
  loadToday();
  renderAll();
})();
</script>
</body>
</html>

